[Unit]
Description=Campus AI Community FastAPI Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=liuhemu
Group=liuhemu
WorkingDirectory=/home/ldaphome/liuhemu/document/Campus-AI-Demo-Community/backend
Environment=PATH=/home/ldaphome/liuhemu/miniconda3/envs/campusai/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin
ExecStart=/home/ldaphome/liuhemu/miniconda3/envs/campusai/bin/uvicorn app.main:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
