APP_NAME=Campus AI API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_BACKEND=demo
DEMO_USERNAME=admin
DEMO_PASSWORD=admin123
DEMO_DISPLAY_NAME=Campus Admin
DEMO_EMP_ID=
TOKEN_TTL_HOURS=12
SESSION_COOKIE_NAME=campus_ai_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=campusai
MYSQL_PASSWORD=
MYSQL_DATABASE=campus_ai
MYSQL_CHARSET=utf8mb4
MYSQL_USER_TABLE=users
SSO_DOMAIN=https://devsso.hkust-gz.edu.cn
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=http://10.120.17.138:8080/signin-oidc
SSO_POST_LOGOUT_REDIRECT_URI=http://10.120.17.138:8080/signout-callback
SSO_SCOPE=openid profile
SSO_USER_PERSISTENCE_ENABLED=true
SSO_USER_TABLE=sso_users

# Harbor 镜像仓库。工作台查询当前登录用户邮箱对应的私有项目；点击“保存容器”时自动确保用户私有项目存在。
HARBOR_URL=http://10.120.17.137:5053/api/v2.0/
HARBOR_REGISTRY=gpunion2.io
HARBOR_ADMIN_USERNAME=
HARBOR_ADMIN_PASSWORD=
HARBOR_USER_DEFAULT_PASSWORD=Habor!123
HARBOR_USER_DEFAULT_STORAGE_QUOTA=53687091200
HARBOR_USER_PROJECT_SUFFIX=-repo
# 工作台“公有镜像”区域使用的 Harbor 项目；后续可替换为本项目专用公共镜像项目。
HARBOR_PUBLIC_PROJECT=dev
HARBOR_REQUEST_TIMEOUT_SECONDS=10

USER_MAX_STORAGE=10

# K3s 容器申请。点击“申请容器”时，先确保存在以 emp_id 命名的 namespace，再创建 devbox Pod。
KUBECONFIG_PATH=
K3S_CONFIG_PATH=/etc/rancher/k3s/k3s.yaml
K3S_DEVBOX_IMAGE=gpunion2.io/dev/devbox:latest
K3S_DEVBOX_CPU=2
K3S_DEVBOX_MEMORY=4Gi
K3S_DEVBOX_COMMAND=/bin/sh,-c,sleep infinity
# devbox Pod 使用固定上游 DNS，绕过当前 kube-dns 外部域名解析超时问题；留空则恢复 ClusterFirst。
K3S_DEVBOX_DNS_NAMESERVERS=10.90.63.2,10.90.63.3,8.8.8.8
# 保存容器：后端会创建特权 Job，在原 Pod 所在节点通过 nerdctl commit 并推送到 Harbor 私有项目。
K3S_COMMIT_NERDCTL_IMAGE=gpunion2.io/library/nerdctl:latest
K3S_COMMIT_HOST_CONTAINERD_SOCKET=/run/k3s/containerd/containerd.sock
K3S_COMMIT_CONTAINERD_SOCKET=/run/containerd/containerd.sock
K3S_COMMIT_INSECURE_REGISTRY=true
# 保存容器时实际 nerdctl login/push 的 registry；留空会从 HARBOR_URL 自动取 10.120.17.137:5053。
# 不要写 http:// 前缀到镜像 tag 中；如需显式配置，写 10.120.17.137:5053。
K3S_COMMIT_PUSH_REGISTRY=
K3S_APPS_HOST=gpunion.hkust-gz.edu.cn
K3S_APPS_PATH_PREFIX=/apps
K3S_APPS_PUBLIC_BASE_URL=https://gpunion.hkust-gz.edu.cn/apps

# WebSSH / 原生 SSH 网关。第一版原生 SSH 暴露在局域网 10.120.17.138:2222。
SSH_GATEWAY_ENABLED=true
SSH_GATEWAY_HOST=0.0.0.0
SSH_GATEWAY_PORT=2222
SSH_GATEWAY_PUBLIC_HOST=10.120.17.138
# 建议生产环境配置固定 HostKey，避免后端重启后原生 SSH 客户端出现 host key 变化警告。
SSH_GATEWAY_HOST_KEY_PATH=
WEBSSH_PUBLIC_PATH_PREFIX=/ssh

# 应用市场封面：第一版使用后端本地 static/covers 存储轻量压缩图，后续可替换为图床/对象存储。
PUBLISHED_COVER_STORAGE_DIR=static/covers
PUBLISHED_COVER_PUBLIC_PREFIX=/api/static/covers
PUBLISHED_COVER_MAX_BYTES=1048576
