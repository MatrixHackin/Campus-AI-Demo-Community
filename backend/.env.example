APP_NAME=Campus AI Sandbox API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTH_BACKEND=demo
DEMO_USERNAME=admin
DEMO_PASSWORD=admin123
DEMO_DISPLAY_NAME=Campus Admin
TOKEN_TTL_HOURS=12
SESSION_COOKIE_NAME=campus_ai_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=campusai
MYSQL_PASSWORD=
MYSQL_DATABASE=campus_ai
MYSQL_CHARSET=utf8mb4
MYSQL_USER_TABLE=users
SSO_DOMAIN=https://devsso.hkust-gz.edu.cn
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=http://10.120.17.138:8080/signin-oidc
SSO_POST_LOGOUT_REDIRECT_URI=http://10.120.17.138:8080/signout-callback
SSO_SCOPE=openid profile
SSO_USER_PERSISTENCE_ENABLED=true
SSO_USER_TABLE=sso_users

# Kubernetes / K3s
KUBERNETES_NAMESPACE=campus-sandbox
# shared: 所有用户 Pod 放入 KUBERNETES_NAMESPACE；user: 每个用户单独 namespace
SANDBOX_NAMESPACE_MODE=shared
# 可优先用 KUBECONFIG_PATH；未配置时默认使用 K3S_CONFIG_PATH
KUBECONFIG_PATH=
K3S_CONFIG_PATH=/etc/rancher/k3s/k3s.yaml
DEFAULT_SANDBOX_IMAGE=python:3.11-slim
DEFAULT_SANDBOX_COMMAND=/bin/sh,-c,sleep infinity
DEFAULT_SANDBOX_USERNAME=user
DEFAULT_SANDBOX_PASSWORD=password
DEFAULT_SANDBOX_GPU_COUNT=0
DEFAULT_SANDBOX_CPU=4
DEFAULT_SANDBOX_MEMORY=8Gi
DEFAULT_SANDBOX_SHM_SIZE=8Gi
GPU_CPU_PER_CARD=16
GPU_MEMORY_PER_CARD_GI=48
GPU_SHM_PER_CARD_GI=24
NVIDIA_RUNTIME_CLASS_NAME=nvidia
ASCEND_IMAGE_NAME=gpunion2.io/cann
ENABLE_SANDBOX_NODEPORT=true
SANDBOX_SSH_PORT=22
SANDBOX_WAIT_UNTIL_RUNNING=false
SANDBOX_WAIT_TIMEOUT_SECONDS=120

# Harbor（敏感信息请只放 .env，不要提交真实密码）
HARBOR_URL=http://10.120.17.137:5053/api/v2.0/
HARBOR_REGISTRY=gpunion2.io
HARBOR_ADMIN_USERNAME=
HARBOR_ADMIN_PASSWORD=
HARBOR_USER_DEFAULT_PASSWORD=
HARBOR_USER_DEFAULT_STORAGE_QUOTA=53687091200
HARBOR_PUBLIC_PROJECT=library
HARBOR_DEV_PROJECT=dev

# Prometheus
PROMETHEUS_URL=http://10.43.146.195:9090
USER_MAX_STORAGE=512.00
